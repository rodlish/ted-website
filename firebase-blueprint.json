{
  "entities": {
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation session between a user and the chatbot",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique session ID" },
        "startTime": { "type": "string", "format": "date-time", "description": "When the session started" },
        "lastUpdateTime": { "type": "string", "format": "date-time", "description": "When the last message was sent" },
        "userEmail": { "type": "string", "format": "email", "description": "Optional user email if provided" },
        "metadata": { "type": "object", "description": "Additional session info (browser, country, etc.)" }
      },
      "required": ["id", "startTime", "lastUpdateTime"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message within a chat session",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "bot"], "description": "Who sent the message" },
        "content": { "type": "string", "description": "The message text" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/chat_sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Root collection for chat sessions"
    },
    "/chat_sessions/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Subcollection for messages within a session"
    }
  }
}
